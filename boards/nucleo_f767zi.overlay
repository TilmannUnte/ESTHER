&usart2 {
	pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6>;
	pinctrl-names = "default";
	current-speed = <38400>;
	status = "okay";
	rplidar_0 {
		compatible = "slamtech,rplidar";
		status = "okay";
	};
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pb14 &usart1_rx_pb15>;
	pinctrl-names = "default";
	current-speed = <38400>;
	status = "okay";
	
	magni_0 {
		compatible = "ur,magni";
	};
};
