/ {
	chosen {
		zephyr,console = &usic1ch0;
		zephyr,shell-uart = &usic1ch0;
	};
};

&usic1ch1 {
/*	compatible = "infineon,xmc4xxx-uart";
	current-speed = <115200>;
	pinctrl-0 = <&uart_tx_p0_1_u1c1 &uart_rx_p0_0_u1c1>;
	pinctrl-names = "default";
	input-src = "DX0D";
	interrupts = <90 1 91 1>;
	interrupt-names = "tx", "rx";
	fifo-start-offset = <0>;
	fifo-tx-size = <16>;
	fifo-rx-size = <16>;*/
	status = "disabled";
};

&eth {
	status = "disabled";
/*	pinctrl-0 = <&eth_p2_4_rxer &eth_p2_2_rxd0 &eth_p2_3_rxd1
		     &eth_p15_8_clk_rmii &eth_p15_9_crs_dv &eth_p2_5_tx_en
		     &eth_p2_8_txd0 &eth_p2_9_txd1>;
	pinctrl-names = "default";

	rxer-port-ctrl = "P2_4";
	rxd0-port-ctrl = "P2_2";
	rxd1-port-ctrl = "P2_3";
	rmii-rx-clk-port-ctrl = "P15_8";
	crs-rx-dv-port-ctrl = "P15_9";

	phy-connection-type = "rmii";
	phy-handle = <&phy>;*/
};

&mdio {
	status = "disabled";
/*
	mdi-port-ctrl = "P2_0";
	pinctrl-0 = <&eth_p2_0_mdo &eth_p2_7_mdc>;
	pinctrl-names = "default";

	phy: ethernet-phy@0 {
		compatible = "ethernet-phy";
		reg = <0>;
	};
	*/
};

&rtc {
	status = "disabled";
};

&usic1ch0 {
	compatible = "infineon,xmc4xxx-uart";
	current-speed = <115200>;
	pinctrl-0 = <&uart_tx_p2_14_u1c0 &uart_rx_p2_15_u1c0>;
	pinctrl-names = "default";
	input-src = "DX0C";
	interrupts = <90 1 91 1>; // TODO
	interrupt-names = "tx", "rx";
	fifo-start-offset = <0>;
	fifo-tx-size = <16>;
	fifo-rx-size = <16>;
	data-bits = <8>;
	stop-bits = "1";
	status = "okay";
};

&usic2ch0 {
	compatible = "infineon,xmc4xxx-uart";
	current-speed = <115200>;
	pinctrl-0 = <&uart_tx_p5_0_u2c0 &uart_rx_p5_1_u2c0>;
	pinctrl-names = "default";
	input-src = "DX0A"; /* Adjust if you want a different input pin! See p. 17-228 in the XMC45 manual */
	interrupts = <96 1 97 1>; // FIXME: Please review this!
	interrupt-names = "tx", "rx";
	fifo-start-offset = <0>;
	fifo-tx-size = <16>;  /* This was copied from the board config */
	fifo-rx-size = <16>; /* See above comment */
	data-bits = <8>;
	stop-bits = "1";
	status = "okay";
	
	rplidar_0 {
		compatible = "slamtech,rplidar";
		status = "okay";
		/*pwms = <&pwm_ccu42 3 65536 PWM_POLARITY_NORMAL>;*/
	};
};

&usic0ch0 {
	compatible = "infineon,xmc4xxx-uart";
	current-speed = <38400>;
	pinctrl-0 = <&uart_tx_p1_5_u0c0 &uart_rx_p1_4_u0c0>;
	pinctrl-names = "default";
	input-src = "DX0B"; /* Adjust if you want a different input pin! See p. 17-228 in the XMC45 manual */
	interrupts = <84 1 85 1>; // FIXME: Please review this!
	interrupt-names = "tx", "rx";
	fifo-start-offset = <0>; /* Every USIC has a FIFO shared between two channels */
	fifo-tx-size = <16>;  /* This was copied from the board config */
	fifo-rx-size = <16>; /* See above comment */
	data-bits = <8>;
	stop-bits = "1";
	status = "okay";
	
	magni_0 {
		compatible = "ur,magni";
	};
};

/* The following values were all copied from the standard board config */
&uart_tx_p5_0_u2c0 {
	drive-strength = "strong-soft-edge";
	drive-push-pull;
	hwctrl = "disabled";
};

&uart_rx_p5_1_u2c0 {
	drive-strength = "strong-soft-edge";
	hwctrl = "disabled";
};

&uart_tx_p1_5_u0c0 {
	drive-strength = "strong-soft-edge";
	drive-push-pull;
	hwctrl = "disabled";
};

&uart_rx_p1_4_u0c0 {
	drive-strength = "strong-soft-edge";
	hwctrl = "disabled";
};

&uart_tx_p2_14_u1c0 {
	drive-strength = "strong-soft-edge";
	drive-push-pull;
	hwctrl = "disabled";
};

&uart_rx_p2_15_u1c0 {
	drive-strength = "strong-soft-edge";
	hwctrl = "disabled";
};
